SOURCE_URL="https://github.com/rclone/rclone"
DESCRIPTION="rsync for cloud storage"

check_update() {
  gh_latest_release rclone/rclone
  version="${LATEST_TAG#v}"
  [ "$version" != "${1:-}" ]
}

get_version() {
  local current="${1:-}"
  gh_latest_release rclone/rclone
  version="${LATEST_TAG#v}"

  echo "$RELEASE_BODY"
}
