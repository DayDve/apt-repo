#!/usr/bin/env bash
set -e

current_version="$1"
release=$(gh api repos/rclone/rclone/releases/latest 2>/dev/null)
tag=$(echo "$release" | jq -r '.tag_name')
version="${tag#v}"

echo "version=$version"
echo "source=https://github.com/rclone/rclone"
echo "---"

echo "$release" | jq -r '.body' 2>/dev/null || true
