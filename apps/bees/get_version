#!/usr/bin/env bash
set -e

tmp="$(mktemp -d)"
cd "$tmp"
git init -q
git remote add origin https://github.com/Zygo/bees.git
git fetch --depth=200 --tags -q origin 2>/dev/null
git checkout -q FETCH_HEAD
version="$(git describe --always --dirty | sed 's/^[vV]//')"
echo "version=$version"
echo "---"
git log --oneline -20
cd / && rm -rf "$tmp"
