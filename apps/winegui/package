# ============================================================
# Package script for winegui
# ============================================================

SOURCE_URL="https://github.com/winegui/WineGUI"
DESCRIPTION="Wine prefix manager with a modern GUI"

check_update() {
  gh_latest_release winegui/WineGUI
  version="${LATEST_TAG#v}"
  [ "$version" != "${1:-}" ]
}

get_version() {
  gh_latest_release winegui/WineGUI
  version="${LATEST_TAG#v}"
  local releases_url="https://gitlab.melroy.org/melroy/winegui/-/releases"
  local desc
  desc=$(fetch_url "$releases_url" -H "Accept: application/json" \
    | jq -r '.[0].description // empty' 2>/dev/null)
  [ -n "$desc" ] && printf '%s' "$desc" || printf 'Подробный лог: %s' "$releases_url"
}
