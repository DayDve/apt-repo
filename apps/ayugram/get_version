#!/usr/bin/env bash
set -e

current_version="$1"

tag=$(gh api repos/AyuGram/AyuGramDesktop/releases --jq '.[0].tag_name' 2>/dev/null || echo "unknown")
tag_ref=$(gh api "repos/AyuGram/AyuGramDesktop/git/refs/tags/$tag" --jq '.object' 2>/dev/null || echo "")
tag_type=$(echo "$tag_ref" | jq -r '.type // empty')
if [ "$tag_type" = "commit" ]; then
  tag_sha=$(echo "$tag_ref" | jq -r '.sha')
else
  tag_sha=$(echo "$tag_ref" | jq -r '.object.sha // empty')
fi

head_sha=$(gh api repos/AyuGram/AyuGramDesktop/commits/dev --jq '.sha' 2>/dev/null || echo "")

if [ -n "$tag_sha" ] && [ -n "$head_sha" ]; then
  ahead=$(gh api "repos/AyuGram/AyuGramDesktop/compare/$tag_sha...$head_sha" --jq '.ahead_by' 2>/dev/null || echo "0")
else
  ahead="0"
fi

version="${tag#v}-${ahead}-g$(echo "$head_sha" | cut -c1-7)"

echo "version=$version"
echo "---"

gh api repos/AyuGram/AyuGramDesktop/releases --jq '.[0].body' 2>/dev/null || true

if [ "$ahead" -gt 0 ] && [ -n "$current_version" ]; then
  current_sha=$(echo "$current_version" | sed 's/.*-g//')
  if [ -n "$current_sha" ] && [ "$current_sha" != "$head_sha" ]; then
    printf '\nCommits since last build:\n'
    gh api "repos/AyuGram/AyuGramDesktop/compare/$current_sha...$head_sha" \
      --jq '.commits[] | "\(.sha[0:7]) \(.commit.message | split("\n")[0])"' 2>/dev/null || true
  fi
fi
