BUILD_MODE=run
SOURCE_URL="https://github.com/AyuGram/AyuGramDesktop"
DESCRIPTION="Telegram client with enhanced features"

check_update() {
  local current="${1:-}"
  local tag tag_ref tag_type tag_sha dev_sha ahead

  tag=$(gh api repos/AyuGram/AyuGramDesktop/releases --jq '.[0].tag_name' 2>/dev/null || echo "unknown")
  tag_ref=$(gh api "repos/AyuGram/AyuGramDesktop/git/refs/tags/$tag" --jq '.object' 2>/dev/null || echo "")
  tag_type=$(echo "$tag_ref" | jq -r '.type // empty')
  if [ "$tag_type" = "commit" ]; then
    tag_sha=$(echo "$tag_ref" | jq -r '.sha')
  else
    tag_sha=$(echo "$tag_ref" | jq -r '.object.sha // empty')
  fi

  dev_sha=$(gh api repos/AyuGram/AyuGramDesktop/commits/dev --jq '.sha' 2>/dev/null || echo "")

  if [ -n "$tag_sha" ] && [ -n "$dev_sha" ]; then
    ahead=$(gh api "repos/AyuGram/AyuGramDesktop/compare/$tag_sha...$dev_sha" --jq '.ahead_by' 2>/dev/null || echo "0")
  else
    ahead="0"
  fi

  version="${tag#v}-${ahead}-g${dev_sha:0:7}"
  [ "$version" != "$current" ]
}

get_version() {
  local current="${1:-}"
  local tag tag_ref tag_type tag_sha dev_sha ahead

  tag=$(gh api repos/AyuGram/AyuGramDesktop/releases --jq '.[0].tag_name' 2>/dev/null || echo "unknown")
  tag_ref=$(gh api "repos/AyuGram/AyuGramDesktop/git/refs/tags/$tag" --jq '.object' 2>/dev/null || echo "")
  tag_type=$(echo "$tag_ref" | jq -r '.type // empty')
  if [ "$tag_type" = "commit" ]; then
    tag_sha=$(echo "$tag_ref" | jq -r '.sha')
  else
    tag_sha=$(echo "$tag_ref" | jq -r '.object.sha // empty')
  fi

  dev_sha=$(gh api repos/AyuGram/AyuGramDesktop/commits/dev --jq '.sha' 2>/dev/null || echo "")

  if [ -n "$tag_sha" ] && [ -n "$dev_sha" ]; then
    ahead=$(gh api "repos/AyuGram/AyuGramDesktop/compare/$tag_sha...$dev_sha" --jq '.ahead_by' 2>/dev/null || echo "0")
  else
    ahead="0"
  fi

  version="${tag#v}-${ahead}-g${dev_sha:0:7}"

  gh_release_body AyuGram/AyuGramDesktop

  if [ "$ahead" -gt 0 ] && [ -n "$current" ]; then
    local current_sha
    current_sha=$(echo "$current" | sed 's/.*-g//')
    if [ -n "$current_sha" ] && [ "$current_sha" != "$dev_sha" ]; then
      printf '\nCommits since last build:\n'
      gh_commits_between AyuGram/AyuGramDesktop "$current_sha" "$dev_sha"
    fi
  fi
}

run_build() {
  local ccache_dir="$dir/ccache" img="$DOCKER_IMAGE_NAME:$version"
  mkdir -p "$ccache_dir"
  chmod 777 "$ccache_dir"

  docker run --rm \
    --mount type=bind,source="$ccache_dir",target=/build/ccache \
    --mount type=bind,source=/tmp/deb-out,target=/out \
    --env VER="$version" \
    --env FN="$DEBFULLNAME" \
    --env EM="$DEBEMAIL" \
    "$img" \
    bash -e << 'SCRIPT'
chown -R user:user /build/ccache
su user -c '
  export CCACHE_DIR=/build/ccache
  export CCACHE_MAXSIZE=10G
  export CCACHE_COMPRESS=1
  export CCACHE_SLOPPINESS=include_file_ctime,include_file_mtime,pch_defines,time_macros
  export CCACHE_COMPILERCHECK=content
  export CCACHE_BASEDIR=/build
  export CCACHE_NOHASHDIR=1
  export CCACHE_CPP2=1
  cd /build/src/Telegram
  ./configure.sh \
    -D TDESKTOP_API_ID=2040 \
    -D TDESKTOP_API_HASH=b18441a1ff607e10a989891a5462e627 \
    -D CMAKE_C_COMPILER_LAUNCHER=ccache \
    -D CMAKE_CXX_COMPILER_LAUNCHER=ccache
  cmake --build ../out --config Release -j$(nproc)
'
test -f /build/src/out/Release/AyuGram

cp /build/src/out/Release/AyuGram /usr/bin/aygram-desktop
cp /build/src/.github/AyuGram.png /usr/share/icons/hicolor/512x512/apps/com.ayugram.desktop.png

mkdir -p /DEBIAN /usr/share/applications /usr/share/dbus-1/services
cat > /DEBIAN/control << CONTROL
Package: ayugram
Version: $VER
Section: net
Priority: optional
Architecture: amd64
Maintainer: $FN <$EM>
Depends: libc6, ca-certificates
Description: AyuGram Desktop
 ToS breaking Telegram client with enhanced features.
CONTROL

cat > /DEBIAN/postinst << 'POSTINST'
#!/bin/sh
set -e
chmod +x /usr/share/applications/com.ayugram.desktop
chattr +i /usr/share/applications/com.ayugram.desktop
exit 0
POSTINST
chmod 755 /DEBIAN/postinst

cat > /DEBIAN/prerm << 'PRERM'
#!/bin/sh
set -e
chattr -i /usr/share/applications/com.ayugram.desktop 2>/dev/null || true
exit 0
PRERM
chmod 755 /DEBIAN/prerm

cat > /usr/share/applications/com.ayugram.desktop << 'DESKTOP'
[Desktop Entry]
Name=AyuGram Desktop
Comment=Desktop version of AyuGram - ToS breaking Telegram client
Comment[ru_RU]=Альтернативный мессенджер для Telegram
Exec=env DESKTOPINTEGRATION=1 /usr/bin/aygram-desktop -- %%u
Icon=com.ayugram.desktop
Terminal=false
StartupWMClass=AyuGram
Type=Application
Categories=Chat;Network;InstantMessaging;Qt;
MimeType=x-scheme-handler/tg;x-scheme-handler/tonsite;
Keywords=tg;chat;im;messaging;messenger;sms;telegram;tdesktop;
Actions=quit;
DBusActivatable=true
SingleMainWindow=true
X-GNOME-UsesNotifications=true
X-GNOME-SingleWindow=true

[Desktop Action quit]
Exec=env DESKTOPINTEGRATION=1 /usr/bin/aygram-desktop -quit
Name=Quit AyuGram
Icon=application-exit
DESKTOP

cat > /usr/share/dbus-1/services/com.ayugram.service << 'DBUS'
[D-BUS Service]
Name=com.ayugram.desktop
Exec=/usr/bin/aygram-desktop
DBUS

dpkg-deb --root-owner-group --build . /out/ayugram_${VER}_amd64.deb
SCRIPT
}
